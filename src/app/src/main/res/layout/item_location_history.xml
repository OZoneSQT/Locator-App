<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeColor="?attr/colorOutlineVariant"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Header row with Grid Locator -->
        <TextView
            android:id="@+id/item_grid_locator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="JO65VM"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:textColor="?attr/colorPrimary"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Call Sign Badge -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chip_call_sign"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OZ1ABC"
            android:layout_marginStart="12dp"
            style="@style/Widget.MaterialComponents.ChipGroup"
            app:chipBackgroundColor="?attr/colorSecondaryContainer"
            app:layout_constraintTop_toTopOf="@id/item_grid_locator"
            app:layout_constraintStart_toEndOf="@id/item_grid_locator"
            app:layout_constraintBottom_toBottomOf="@id/item_grid_locator" />

        <!-- Delete button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_delete"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/button_delete"
            style="@style/Widget.Material3.Button.TextButton"
            app:cornerRadius="8dp"
            app:layout_constraintTop_toTopOf="@id/item_grid_locator"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/item_grid_locator" />

        <!-- GPS Coordinates -->
        <LinearLayout
            android:id="@+id/layout_coordinates"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/item_grid_locator"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_gps"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/item_coordinates"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="55.123456, 9.123456"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSurface"
                android:textIsSelectable="true" />
        </LinearLayout>

        <!-- Height -->
        <LinearLayout
            android:id="@+id/layout_height"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/layout_coordinates"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_height_short"
                android:textAppearance="?attr/textAppearanceLabelMedium"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/item_height"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="57.3 m"
                android:textAppearance="?attr/textAppearanceBodyMedium"
                android:textColor="?attr/colorOnSurface" />
        </LinearLayout>

        <!-- UTC Timestamp -->
        <TextView
            android:id="@+id/item_timestamp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="2026-02-27 14:30:00 UTC"
            android:textAppearance="?attr/textAppearanceBodySmall"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/layout_height"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Weather Data -->
        <com.google.android.material.chip.Chip
            android:id="@+id/item_weather"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌡️ 15.2°C | 💧 65%"
            android:layout_marginTop="8dp"
            style="@style/Widget.Material3.Chip.Filter"
            app:chipBackgroundColor="?attr/colorTertiaryContainer"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/item_timestamp"
            app:layout_constraintStart_toStartOf="parent" />

        <!-- Open in Maps Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_open_maps"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/button_open_maps"
            style="@style/Widget.Material3.Button.TextButton"
            app:cornerRadius="8dp"
            app:layout_constraintTop_toBottomOf="@id/item_weather"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:layout_marginTop="12dp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>

